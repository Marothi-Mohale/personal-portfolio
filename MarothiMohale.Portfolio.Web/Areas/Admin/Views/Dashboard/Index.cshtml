@model AdminDashboardViewModel

<section class="admin-header">
    <p class="eyebrow">Admin Dashboard</p>
    <h1>Portfolio content workspace</h1>
</section>

<section class="admin-stats">
    <article class="stat-card"><strong>@Model.ProjectsCount</strong><span>Projects</span></article>
    <article class="stat-card"><strong>@Model.SkillsCount</strong><span>Skills</span></article>
    <article class="stat-card"><strong>@Model.ExperiencesCount</strong><span>Experiences</span></article>
    <article class="stat-card"><strong>@Model.TestimonialsCount</strong><span>Testimonials</span></article>
    <article class="stat-card"><strong>@Model.ContactMessagesCount</strong><span>Messages</span></article>
</section>
