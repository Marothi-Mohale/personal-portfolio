@model HomePageViewModel

<section class="hero-section">
    <div class="hero-backdrop" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-one" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-two" aria-hidden="true"></div>
    <div class="container hero-grid">
        <div class="hero-copy reveal reveal-up">
            <p class="eyebrow">Software Developer</p>
            <h1>Marothi Mohale builds dependable <span class="text-gradient">C# / ASP.NET Core</span> products with full-stack care and growing data engineering depth.</h1>
            <p class="lead">@Model.Profile.ProfessionalSummary</p>
            <div class="hero-actions">
                <a class="button button-primary" href="@Model.Profile.HeroPrimaryCtaUrl">Explore projects</a>
                <a class="button button-secondary" href="@Model.Profile.HeroSecondaryCtaUrl">Start a conversation</a>
            </div>
            <div class="trust-strip">
                <span>Recruiter-ready presentation</span>
                <span>Production-minded .NET architecture</span>
                <span>Responsive custom UI</span>
            </div>
            <ul class="hero-metrics">
                <li><strong>@Model.FeaturedProjects.Count</strong><span>Featured portfolio builds</span></li>
                <li><strong>@Model.SkillGroups.Count</strong><span>Core technical domains</span></li>
                <li><strong>@Model.Services.Count</strong><span>Client-facing service lanes</span></li>
            </ul>
        </div>
        <div class="hero-stack reveal reveal-up-delayed">
            <div class="hero-panel hero-profile-card hero-profile-card-float">
                <div class="hero-profile-intro">
                    <p class="eyebrow">Positioning</p>
                    <span class="hero-availability">Open to software opportunities</span>
                </div>
                <div class="hero-portrait-shell circular-portrait-shell">
                    <div class="hero-portrait-ring"></div>
                    <img src="~/images/marothi-profile.jfif" asp-append-version="true" alt="Portrait of Marothi Mohale" class="hero-portrait circular-portrait" data-fallback-image="/images/project-custom.svg" />
                </div>
                <h2>@Model.Profile.FullName</h2>
                <p>@Model.Profile.About</p>
                <div class="hero-role-list">
                    <span class="badge badge-strong">C# / ASP.NET Core builder</span>
                    <span class="badge">Full-stack web developer</span>
                    <span class="badge">Data engineering enthusiast</span>
                    <span class="badge">BSc Computer Science and Business Computing</span>
                </div>
            </div>
            <div class="hero-proof-grid hero-proof-grid-creative">
                <article class="proof-card">
                    <p class="proof-label">Core focus</p>
                    <strong>Business-ready web systems</strong>
                    <span>Backend reliability, clean UX, and maintainable delivery.</span>
                </article>
                <article class="proof-card">
                    <p class="proof-label">Preferred stack</p>
                    <strong>.NET 8, EF Core, SQLite, Docker</strong>
                    <span>Modern server-rendered architecture with practical operational discipline.</span>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="section trust-section">
    <div class="container trust-grid">
        <article class="trust-card reveal reveal-up">
            <p class="eyebrow">Why This Portfolio Works</p>
            <h3>Built to help hiring teams evaluate judgment, not just syntax.</h3>
            <p>Every section is designed to communicate product thinking, technical range, and the ability to ship polished software end to end.</p>
        </article>
        <article class="trust-stat reveal reveal-up-delayed">
            <strong>ASP.NET Core</strong>
            <span>Production-focused server rendering and admin workflows.</span>
        </article>
        <article class="trust-stat reveal reveal-up-delayed-2">
            <strong>Full-stack delivery</strong>
            <span>UI polish, persistent data, authentication, and deployment readiness.</span>
        </article>
        <article class="trust-stat reveal reveal-up-delayed-3">
            <strong>Structured content</strong>
            <span>Seeded database content with clean admin editing paths.</span>
        </article>
    </div>
</section>

<section class="section">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">Featured Projects</p>
            <h2>Selected work shaped with technical depth and product restraint.</h2>
        </div>
        <a class="text-link" asp-controller="Projects" asp-action="Index">See all projects</a>
    </div>
    <div class="container featured-projects-grid">
        @foreach (var project in Model.FeaturedProjects)
        {
            <article class="card project-card editorial-card reveal reveal-up">
                <div class="project-card-media">
                    <img src="@project.ImageUrl" alt="" class="project-image" data-fallback-image="/images/project-custom.svg" />
                    <div class="project-overlay">
                        <span class="badge badge-strong">Featured</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="card-topline">
                        <h3>@project.Title</h3>
                    </div>
                    <p class="meta-line">@project.TechStack</p>
                    <p>@project.ShortDescription</p>
                    <div class="link-row">
                        <a class="text-link" asp-controller="Projects" asp-action="Details" asp-route-slug="@project.Slug">View case study</a>
                        @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                        {
                            <a class="text-link" href="@project.GitHubUrl" target="_blank" rel="noreferrer">GitHub</a>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
</section>

<section class="section section-alt">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">About</p>
            <h2>Positioned for serious hiring conversations.</h2>
        </div>
    </div>
    <div class="container about-grid">
        <div class="content-panel reveal reveal-up">
            <p>@Model.Profile.About</p>
            <div class="credential-list">
                <div><span>Education</span><strong>BSc in Computer Science and Business Computing</strong></div>
                <div><span>Location</span><strong>@Model.Profile.Location</strong></div>
                <div><span>Resume</span><strong><a href="@Model.Profile.ResumeUrl">Download placeholder</a></strong></div>
                <div><span>Focus</span><strong>Web applications, APIs, and data-aware solutions</strong></div>
            </div>
        </div>
        <div class="timeline reveal reveal-up-delayed">
            @foreach (var experience in Model.Experiences)
            {
                <article class="timeline-item">
                    <p class="eyebrow">@experience.Organization</p>
                    <h3>@experience.Title</h3>
                    <p>@experience.Summary</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">Skills</p>
            <h2>Technical strengths presented like capabilities, not buzzwords.</h2>
        </div>
    </div>
    <div class="container premium-skills-grid">
        @foreach (var group in Model.SkillGroups)
        {
            <article class="card skill-panel reveal reveal-up">
                <div class="card-body">
                    <div class="skill-group-header">
                        <h3>@group.Category</h3>
                        <span class="badge">@group.Skills.Count items</span>
                    </div>
                    @foreach (var skill in group.Skills)
                    {
                        <div class="skill-row premium-skill-row">
                            <div>
                                <strong>@skill.Name</strong>
                                <p>@skill.Summary</p>
                            </div>
                            <div class="skill-score">
                                <span>@skill.ProficiencyPercent%</span>
                                <div class="skill-bar"><div style="width:@skill.ProficiencyPercent%"></div></div>
                            </div>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</section>

<section class="section section-alt">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">Services</p>
            <h2>Clear engagement paths for teams, founders, and clients.</h2>
        </div>
    </div>
    <div class="container service-grid">
        @foreach (var service in Model.Services)
        {
            <article class="card service-card reveal reveal-up">
                <div class="card-body">
                    <div class="service-index">@service.DisplayOrder.ToString("00")</div>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                </div>
            </article>
        }
    </div>
</section>

<section class="section">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">Testimonials</p>
            <h2>Social proof structure that’s ready to scale with real collaborations.</h2>
        </div>
    </div>
    <div class="container testimonial-grid">
        @foreach (var testimonial in Model.Testimonials)
        {
            <article class="card quote-card reveal reveal-up">
                <div class="card-body">
                    <p class="quote">"@testimonial.Quote"</p>
                    <div class="testimonial-meta">
                        <p><strong>@testimonial.AuthorName</strong></p>
                        <p>@testimonial.AuthorRole</p>
                    </div>
                </div>
            </article>
        }
    </div>
</section>

<section class="section section-alt">
    <div class="container section-heading">
        <div>
            <p class="eyebrow">Insights</p>
            <h2>Short writing that reinforces technical maturity and product taste.</h2>
        </div>
        <a class="text-link" asp-controller="Blog" asp-action="Index">Browse all insights</a>
    </div>
    <div class="container insight-grid">
        @foreach (var post in Model.BlogPosts)
        {
            <article class="card insight-card reveal reveal-up">
                <div class="card-body">
                    <p class="eyebrow">@post.PublishedAtUtc.ToString("dd MMM yyyy")</p>
                    <h3>@post.Title</h3>
                    <p>@post.Excerpt</p>
                    <a class="text-link" asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug">Read more</a>
                </div>
            </article>
        }
    </div>
</section>
