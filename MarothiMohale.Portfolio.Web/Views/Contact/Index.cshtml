@model ContactPageViewModel

<section class="section page-header">
    <div class="container">
        <p class="eyebrow">Contact</p>
        <h1>Let’s talk about the next build.</h1>
        <p class="lead">Reach out for web development, API delivery, data engineering solutions, or technical training.</p>
    </div>
</section>

<section class="section">
    <div class="container two-column">
        <aside class="content-panel">
            <h2>Contact details</h2>
            <div class="contact-profile-lockup">
                <img src="~/images/marothi-profile.jfif" asp-append-version="true" alt="Portrait of Marothi Mohale" class="contact-portrait" data-fallback-image="/images/project-custom.svg" />
                <div>
                    <p><strong>Marothi Mohale</strong></p>
                    <p>BSc in Computer Science and Business Computing</p>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Profile.Email))
            {
                <p><strong>Email:</strong> @Model.Profile.Email</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Profile.Phone))
            {
                <p><strong>Phone:</strong> @Model.Profile.Phone</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Profile.Location))
            {
                <p><strong>Location:</strong> @Model.Profile.Location</p>
            }
            @foreach (var link in Model.SocialLinks)
            {
                <p><a href="@link.Url" target="_blank" rel="noreferrer">@link.Platform</a></p>
            }
        </aside>

        <div class="card">
            <div class="card-body">
                @if (TempData["ContactSuccess"] is string success)
                {
                    <div class="flash-message">@success</div>
                }
                <form asp-action="Index" method="post" class="form-grid">
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                    <label>
                        Name
                        <input asp-for="Form.Name" />
                        <span asp-validation-for="Form.Name"></span>
                    </label>
                    <label>
                        Email
                        <input asp-for="Form.Email" />
                        <span asp-validation-for="Form.Email"></span>
                    </label>
                    <label>
                        Phone
                        <input asp-for="Form.Phone" />
                        <span asp-validation-for="Form.Phone"></span>
                    </label>
                    <label>
                        Subject
                        <input asp-for="Form.Subject" />
                        <span asp-validation-for="Form.Subject"></span>
                    </label>
                    <label class="form-full">
                        Message
                        <textarea asp-for="Form.Message" rows="6"></textarea>
                        <span asp-validation-for="Form.Message"></span>
                    </label>
                    <button type="submit" class="button button-primary">Send message</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
